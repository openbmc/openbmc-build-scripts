      "writtenOn": "2026-03-12T18:31:52Z",
      "side": 1,
      "message": "What is the advantage of opengrep over ast-grep?  Is there a reason we should choose opengrep?",
      "range": {
        "startLine": 9,
        "startChar": 0,
        "endLine": 9,
        "endChar": 23
      },
      "revId": "1c0d871f95b1b60a9e869ff2918ae3b94a263826",
