properties([
    buildDiscarder(logRotator(daysToKeepStr: '3')),
    parameters([
        string(name: 'GERRIT_REFSPEC', defaultValue: 'refs/heads/master'),
        string(name: 'GERRIT_PROJECT', defaultValue: '')
    ])
])

def branch = ''
def config = [:]
def buildTargets = []

timestamps {
    node('docker-builder') {
        try {
            stage('Checkout Scripts') {
                checkout scm
            }

            stage('Init') {
                config = readJSON file: 'jenkins/machines.json'
                branch = env.GERRIT_BRANCH ?: 'master'
                def machines = config[branch]
                if (machines == null) {
                    error "Unknown branch: ${branch}"
                }
                buildTargets = machines.findAll { k, v -> v.build }.keySet() as List
                buildTargets.add('repotest')
                echo "Building targets for ${branch}: ${buildTargets}"
            }

            stage('Set Build Name') {
                currentBuild.displayName = "#${BUILD_NUMBER}-${env.GERRIT_PATCHSET_UPLOADER_NAME}-${env.GERRIT_PROJECT}"
            }

            stage('Build Matrix') {
                def jobs = [:]
                buildTargets.each { target ->
                    def qemu = config[branch][target]?.qemu
                    try {
                        jobs[target] = build job: './CI-MISC/openbmc-build-target',
                            parameters: [
                                string(name: 'target', value: target),
                                string(name: 'GERRIT_REFSPEC', value: params.GERRIT_REFSPEC),
                                string(name: 'GERRIT_PROJECT', value: params.GERRIT_PROJECT),
                                string(name: 'branch', value: branch),
                                string(name: 'qemu_image', value: qemu?.image ?: ''),
                                string(name: 'qemu_pad', value: qemu?.pad?.toString() ?: '')
                            ],
                            wait: false
                    } catch (Exception e) {
                        echo "Failed to launch build for ${target}: ${e.message}"
                        jobs[target] = null
                    }
                }

                currentBuild.description = buildTargets.collect { target ->
                    def job = jobs[target]
                    if (job == null) {
                        "&#10007; ${target} (not launched)"
                    } else {
                        "<a href=\"${job.absoluteUrl}\">&#9203; ${target}</a>"
                    }
                }.join('<br/>')

                def failures = []
                buildTargets.each { target ->
                    def job = jobs[target]
                    if (job == null) {
                        failures.add(target)
                        return
                    }
                    job.waitForCompletion()

                    if (job.result != 'SUCCESS') {
                        failures.add(target)
                    }

                    currentBuild.description = buildTargets.collect { t ->
                        def j = jobs[t]
                        def icon
                        if (j == null) {
                            icon = '&#10007;'
                        } else if (j.isComplete()) {
                            icon = j.result == 'SUCCESS' ? '&#10003;' : '&#10007;'
                        } else {
                            icon = '&#9203;'
                        }
                        "<a href=\"${j?.absoluteUrl ?: '#'}\">${icon} ${t}</a>"
                    }.join('<br/>')
                }

                echo '=== Build Results ==='
                buildTargets.each { target ->
                    def job = jobs[target]
                    echo "  ${target}: ${job?.result ?: 'NOT_LAUNCHED'}"
                }

                if (failures) {
                    error "Failed targets: ${failures.join(', ')}"
                }
            }
        } finally {
            cleanWs()
        }
    }
}